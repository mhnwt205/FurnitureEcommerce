generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int                   @id @default(autoincrement())
  fullName                 String                @db.NVarChar(255)
  email                    String                @unique @db.VarChar(255)
  passwordHash             String?               @db.VarChar(255)
  phone                    String?               @db.VarChar(20)
  address                  String?               @db.NVarChar(Max)
  role                     String                @default("customer") @db.VarChar(50)
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  emailVerificationExpires DateTime?
  emailVerificationToken   String?               @db.VarChar(255)
  emailVerified            Boolean               @default(false)
  avatarUrl                String?               @db.VarChar(Max)
  googleId                 String?               @db.VarChar(255)
  provider                 String?               @default("credentials") @db.VarChar(50)
  isActive                 Boolean               @default(true)
  position                 String?               @db.NVarChar(100)
  passwordResetExpires     DateTime?
  passwordResetToken       String?               @db.VarChar(255)
  addresses                CustomerAddress[]
  orders                   Order[]
  passwordResetTokens      PasswordResetToken[]
  reviews                  Review[]
  userPermissions          UserPermission[]
  wishlists                Wishlist[]
  consultationRequests     ConsultationRequest[] @relation("CustomerConsultationRequests")
  assignedConsultations    ConsultationRequest[] @relation("AssignedConsultationRequests")
  notifications            Notification[]        @relation("UserNotifications")
  actorNotifications       Notification[]        @relation("ActorNotifications")
  createdPromotions        Promotion[]           @relation("PromotionCreatedBy")
  refreshSessions          RefreshSession[]
}

model RefreshSession {
  id                Int       @id @default(autoincrement())
  userId            Int
  tokenHash         String    @unique @db.VarChar(255)
  familyId          String    @db.VarChar(255)
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId Int?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastUsedAt        DateTime?
  userAgent         String?   @db.NVarChar(512)
  ipAddressHash     String?   @db.VarChar(255)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique @db.VarChar(100)
  name        String           @db.NVarChar(255)
  group       String           @db.VarChar(50)
  description String?          @db.NVarChar(Max)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserPermission[]
}

model UserPermission {
  id           Int        @id @default(autoincrement())
  userId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model Category {
  id                  Int                 @id @default(autoincrement())
  name                String              @db.NVarChar(255)
  slug                String              @unique @db.VarChar(255)
  description         String?             @db.NVarChar(Max)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  products            Product[]
  promotionCategories PromotionCategory[]
}

model Product {
  id                Int                @id @default(autoincrement())
  categoryId        Int
  name              String             @db.NVarChar(255)
  slug              String             @unique @db.VarChar(255)
  description       String?            @db.NVarChar(Max)
  price             Float
  imageUrl          String?            @db.VarChar(Max)
  stock             Int                @default(0)
  color             String?            @db.NVarChar(100)
  material          String?            @db.NVarChar(255)
  widthCm           Float?
  heightCm          Float?
  depthCm           Float?
  dimensions        String?            @db.NVarChar(255)
  roomType          String?            @db.NVarChar(100)
  style             String?            @db.NVarChar(100)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  orderItems        OrderItem[]
  category          Category           @relation(fields: [categoryId], references: [id])
  images            ProductImage[]
  reviews           Review[]
  wishlists         Wishlist[]
  promotionProducts PromotionProduct[]

  @@index([categoryId])
  @@index([isActive])
  @@index([color])
  @@index([material])
  @@index([roomType])
  @@index([style])
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  imageUrl  String   @db.VarChar(Max)
  altText   String?  @db.NVarChar(255)
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id                             Int                  @id @default(autoincrement())
  orderCode                      String               @unique @db.VarChar(50)
  userId                         Int?
  customerEmail                  String               @db.VarChar(255)
  fullName                       String               @db.NVarChar(255)
  phone                          String               @db.VarChar(20)
  address                        String               @db.NVarChar(Max)
  note                           String?              @db.NVarChar(Max)
  paymentMethod                  String               @db.VarChar(50)
  totalAmount                    Float
  status                         String               @default("pending") @db.VarChar(50)
  createdAt                      DateTime             @default(now())
  updatedAt                      DateTime             @updatedAt
  paidAt                         DateTime?
  deliveredAt                    DateTime?
  cancelledAt                    DateTime?
  cancelledBy                    String?              @db.VarChar(50)
  cancellationReasonCode         String?              @db.VarChar(100)
  cancellationReasonText         String?              @db.NVarChar(1000)
  inventoryRestoredAt            DateTime?
  confirmationEmailSentAt        DateTime?
  confirmationEmailStatus        String?              @db.VarChar(50)
  confirmationEmailClaimedAt     DateTime?
  confirmationEmailAttemptCount  Int                  @default(0)
  confirmationEmailLastErrorAt   DateTime?
  confirmationEmailLastErrorCode String?              @db.VarChar(100)
  cancellationEmailSentAt        DateTime?
  cancellationProcessingAt       DateTime?
  activeRefundRequestId          Int?
  managementTokenHash            String?              @db.VarChar(255)
  managementTokenExpiresAt       DateTime?
  managementTokenRevokedAt       DateTime?
  paymentStatus                  String               @default("unpaid") @db.VarChar(50)
  vnpayTransactionNo             String?              @db.VarChar(100)
  vnpayTxnRef                    String?              @db.VarChar(100)
  user                           User?                @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: Cascade)
  orderItems                     OrderItem[]
  paymentRefunds                 PaymentRefund[]      @relation("OrderRefundAttempts")
  activeRefundRequest            PaymentRefund?       @relation("OrderActiveRefundRequest", fields: [activeRefundRequestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviews                        Review[]
  statusHistory                  OrderStatusHistory[]

  @@index([userId])
  @@index([phone])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([managementTokenHash])
  @@index([activeRefundRequestId])
  @@index([confirmationEmailStatus, confirmationEmailClaimedAt])
}

model PaymentRefund {
  id                    Int       @id @default(autoincrement())
  orderId               Int
  requestId             String    @unique @db.VarChar(255)
  provider              String    @db.VarChar(50)
  environment           String    @db.VarChar(50)
  amount                Decimal   @db.Decimal(18, 2)
  status                String    @db.VarChar(50)
  actorType             String    @db.VarChar(50)
  actorUserId           Int?
  processedByUserId     Int?
  processedByName       String?   @db.NVarChar(255)
  reasonCode            String    @db.VarChar(100)
  reasonText            String?   @db.NVarChar(1000)
  adminNote             String?   @db.NVarChar(1000)
  originalOrderStatus   String    @db.VarChar(50)
  claimedAt             DateTime
  processingStartedAt   DateTime?
  providerTransactionId String?   @db.VarChar(255)
  providerResponseCode  String?   @db.VarChar(100)
  failureCode           String?   @db.VarChar(100)
  lastAttemptAt         DateTime?
  attemptCount          Int       @default(0)
  requestedAt           DateTime  @default(now())
  processedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  order                 Order     @relation("OrderRefundAttempts", fields: [orderId], references: [id])
  activeForOrders       Order[]   @relation("OrderActiveRefundRequest")

  @@index([orderId])
  @@index([status])
}

model OrderItem {
  id             Int      @id @default(autoincrement())
  orderId        Int
  productId      Int
  productName    String   @db.NVarChar(255)
  price          Float
  originalPrice  Float?
  discountAmount Float?   @default(0)
  finalPrice     Float?
  promotionId    Int?
  promotionName  String?  @db.NVarChar(255)
  quantity       Int
  subtotal       Float
  order          Order    @relation(fields: [orderId], references: [id])
  product        Product  @relation(fields: [productId], references: [id])
  reviews        Review[]
}

model Review {
  id          Int        @id @default(autoincrement())
  productId   Int
  userId      Int
  orderId     Int
  orderItemId Int?
  rating      Int
  comment     String?    @db.NVarChar(Max)
  images      String?    @db.NVarChar(Max)
  isApproved  Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order       Order      @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, orderItemId])
  @@index([productId, isApproved])
  @@index([userId])
  @@index([orderId])
}

model OrderStatusHistory {
  id            Int      @id @default(autoincrement())
  orderId       Int
  fromStatus    String?  @db.VarChar(50)
  toStatus      String   @db.VarChar(50)
  note          String?  @db.NVarChar(Max)
  cancelReason  String?  @db.NVarChar(Max)
  changedById   Int?
  changedByName String?  @db.NVarChar(255)
  createdAt     DateTime @default(now())
  order         Order    @relation(fields: [orderId], references: [id])
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model CustomerAddress {
  id          Int      @id @default(autoincrement())
  userId      Int
  fullName    String   @db.NVarChar(255)
  phone       String   @db.VarChar(20)
  province    String   @db.NVarChar(100)
  district    String   @db.NVarChar(100)
  ward        String   @db.NVarChar(100)
  addressLine String   @db.NVarChar(Max)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ConsultationRequest {
  id               Int      @id @default(autoincrement())
  requestCode      String   @unique @db.VarChar(50)
  customerId       Int?
  assignedStaffId  Int?
  fullName         String   @db.NVarChar(255)
  phone            String   @db.VarChar(20)
  email            String?  @db.VarChar(255)
  projectType      String?  @db.NVarChar(100)
  roomType         String?  @db.NVarChar(100)
  budgetRange      String?  @db.NVarChar(100)
  preferredContact String?  @db.NVarChar(100)
  message          String?  @db.NVarChar(Max)
  source           String?  @db.VarChar(100)
  status           String   @default("new") @db.VarChar(50)
  internalNote     String?  @db.NVarChar(Max)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  assignedStaff    User?    @relation("AssignedConsultationRequests", fields: [assignedStaffId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer         User?    @relation("CustomerConsultationRequests", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([status])
  @@index([createdAt])
  @@index([phone])
  @@index([email])
  @@index([customerId])
  @@index([assignedStaffId])
}

model Notification {
  id           Int       @id @default(autoincrement())
  recipientId  Int
  actorId      Int?
  type         String    @db.VarChar(100)
  module       String    @db.VarChar(100)
  entityType   String?   @db.VarChar(100)
  entityId     Int?
  title        String    @db.NVarChar(255)
  message      String    @db.NVarChar(Max)
  metadataJson String?   @db.NVarChar(Max)
  readAt       DateTime?
  createdAt    DateTime  @default(now())
  actor        User?     @relation("ActorNotifications", fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  recipient    User      @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([recipientId, readAt])
  @@index([recipientId, createdAt])
  @@index([module])
  @@index([entityType, entityId])
}

model Promotion {
  id                  Int                 @id @default(autoincrement())
  name                String              @db.NVarChar(255)
  description         String?             @db.NVarChar(Max)
  discountType        String              @db.VarChar(50)
  discountValue       Float
  status              String              @default("draft") @db.VarChar(50)
  priority            Int                 @default(0)
  startAt             DateTime
  endAt               DateTime
  isActive            Boolean             @default(true)
  createdById         Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  createdBy           User?               @relation("PromotionCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  promotionProducts   PromotionProduct[]
  promotionCategories PromotionCategory[]

  @@index([status])
  @@index([isActive])
  @@index([startAt])
  @@index([endAt])
  @@index([priority])
  @@index([createdById])
}

model PromotionProduct {
  promotionId Int
  productId   Int
  createdAt   DateTime  @default(now())
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([promotionId, productId])
  @@index([promotionId])
  @@index([productId])
}

model PromotionCategory {
  promotionId Int
  categoryId  Int
  createdAt   DateTime  @default(now())
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([promotionId, categoryId])
  @@index([promotionId])
  @@index([categoryId])
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  tokenHash String    @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}
